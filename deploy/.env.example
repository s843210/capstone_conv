# ============================================
# 환경변수 템플릿
# 이 파일을 backend/conv/.env로 복사한 뒤 실제 값을 입력하세요.
# cp deploy/.env.example backend/conv/.env
# chmod 600 backend/conv/.env
# ============================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_store
DB_USER=postgres
DB_PASSWORD=여기에_강력한_비밀번호

# Admin Auth
ADMIN_LOGIN_ID=admin
ADMIN_PASSWORD=여기에_관리자_비밀번호
ADMIN_NAME=관리자
ADMIN_EMAIL=admin@example.com

# JWT
JWT_SECRET=여기에_충분히_긴_랜덤_문자열_64자이상_권장
JWT_ISSUER=campus-store
JWT_EXPIRATION_MINUTES=120

# Google OAuth
GOOGLE_CLIENT_IDS=WEB_CLIENT_ID,ANDROID_CLIENT_ID
GOOGLE_ALLOWED_DOMAIN=

# AI
AI_BASE_URL=http://127.0.0.1:8000

# Weather
WEATHER_ENABLED=false
WEATHER_BASE_URL=https://api.openweathermap.org
WEATHER_FORECAST_PATH=/data/2.5/forecast
WEATHER_API_KEY=
WEATHER_LAT=37.2941
WEATHER_LON=127.0448
WEATHER_TIMEOUT_SEC=10
WEATHER_RETRY=3
WEATHER_RETRY_BACKOFF_MS=500
WEATHER_SCHEDULE_CRON=0 40 17 * * *
WEATHER_SCHEDULE_ZONE=Asia/Seoul

# Holiday API
HOLIDAY_ENABLED=true
HOLIDAY_INCLUDE_WEEKEND=true
HOLIDAY_API_ENABLED=true
HOLIDAY_BASE_URL=https://date.nager.at
HOLIDAY_PUBLIC_HOLIDAY_PATH=/api/v3/PublicHolidays/{year}/{countryCode}
HOLIDAY_COUNTRY_CODE=KR
HOLIDAY_TIMEOUT_SEC=8
HOLIDAY_RETRY=2
HOLIDAY_RETRY_BACKOFF_MS=300

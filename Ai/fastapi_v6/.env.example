# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/fastapi_v6
DATABASE_URL=sqlite:///./fastapi_v6.sqlite3
SPRING_BASE_URL=http://127.0.0.1:8080
SPRING_AI_PATH=/api/ai/predictions
